---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../utils/url';

interface Props {
  country: CollectionEntry<'countries'>;
  trekCount?: number;
  regionCount?: number;
}
const { country, trekCount, regionCount } = Astro.props;
const { name, slug, tagline, heroImage } = country.data;
---

<a
  href={withBase(`/${slug}/`)}
  class="group relative flex h-80 flex-col justify-end overflow-hidden rounded-2xl shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
>
  <img
    src={withBase(heroImage.src)}
    alt={heroImage.alt}
    loading="lazy"
    class="absolute inset-0 h-full w-full object-cover transition duration-300 group-hover:scale-105"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-forest-950/90 via-forest-950/30 to-transparent"></div>
  <div class="relative p-6 text-white">
    <h3 class="font-display text-2xl">{name}</h3>
    <p class="mt-1 text-sm text-sand-100/90">{tagline}</p>
    <div class="mt-3 flex gap-4 text-xs font-semibold uppercase tracking-wide text-terracotta-300">
      {regionCount !== undefined && <span>{regionCount} Regions</span>}
      {trekCount !== undefined && <span>{trekCount} Treks</span>}
    </div>
  </div>
</a>
