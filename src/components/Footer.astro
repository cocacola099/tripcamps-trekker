---
import { getCollection } from 'astro:content';
import { COUNTRY_ORDER, REGIONS_BY_COUNTRY } from '../data/regions';
import { withBase } from '../utils/url';

const regions = await getCollection('regions');
const countries = await getCollection('countries');
const orderedCountries = COUNTRY_ORDER.map((slug) => {
  const country = countries.find((c) => c.data.slug === slug);
  const countryRegions = REGIONS_BY_COUNTRY[slug]
    .map((regionSlug) => regions.find((r) => r.data.slug === regionSlug && r.data.countrySlug === slug))
    .filter(Boolean);
  return country ? { country, regions: countryRegions } : null;
}).filter(Boolean);

const year = new Date().getFullYear();
---

<footer class="border-t border-forest-100 bg-forest-950 text-sand-100">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-4">
    <div>
      <p class="font-display text-xl text-white">Tripcamps</p>
      <p class="mt-3 text-sm text-forest-200">
        Information and support to help you plan and organise trekking trips across the globe — starting with India and Nepal.
      </p>
      <a class="mt-3 block text-sm text-forest-200 hover:text-terracotta-300" href="mailto:tripcamps.sales@gmail.com">tripcamps.sales@gmail.com</a>
    </div>

    <div>
      <p class="font-semibold text-white">Explore</p>
      <ul class="mt-3 space-y-2 text-sm text-forest-200">
        <li><a class="hover:text-terracotta-300" href={withBase('/treks')}>All Treks</a></li>
        <li><a class="hover:text-terracotta-300" href={withBase('/regions')}>All Regions</a></li>
        <li><a class="hover:text-terracotta-300" href={withBase('/shop')}>Shop</a></li>
        <li><a class="hover:text-terracotta-300" href={withBase('/about')}>About Us</a></li>
        <li><a class="hover:text-terracotta-300" href={withBase('/contact')}>Contact</a></li>
      </ul>
    </div>

    {orderedCountries.map((entry) => entry && (
      <div>
        <p class="font-semibold text-white">
          <a class="hover:text-terracotta-300" href={withBase(`/${entry.country.data.slug}/`)}>{entry.country.data.name}</a>
        </p>
        <ul class="mt-3 space-y-2 text-sm text-forest-200">
          {entry.regions.map((region) => region && (
            <li><a class="hover:text-terracotta-300" href={withBase(`/${entry.country.data.slug}/regions/${region.data.slug}/`)}>{region.data.name}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="border-t border-forest-800 px-4 py-6 text-center text-xs text-forest-300 sm:px-6">
    &copy; {year} Tripcamps. All rights reserved.
  </div>
</footer>
