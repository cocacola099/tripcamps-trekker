---
import { getCollection } from 'astro:content';
import { REGION_ORDER } from '../data/regions';

const regions = await getCollection('regions');
const orderedRegions = REGION_ORDER
  .map((slug) => regions.find((r) => r.data.slug === slug))
  .filter(Boolean);

const year = new Date().getFullYear();
---

<footer class="border-t border-forest-100 bg-forest-950 text-sand-100">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-4">
    <div>
      <p class="font-display text-xl text-white">Tripcamps</p>
      <p class="mt-3 text-sm text-forest-200">
        Information and support to help you plan and organise trekking trips across the globe — starting with India's Himalaya and Western Ghats.
      </p>
    </div>

    <div>
      <p class="font-semibold text-white">Explore</p>
      <ul class="mt-3 space-y-2 text-sm text-forest-200">
        <li><a class="hover:text-terracotta-300" href="/treks">All Treks</a></li>
        <li><a class="hover:text-terracotta-300" href="/regions">Regions</a></li>
        <li><a class="hover:text-terracotta-300" href="/shop">Shop</a></li>
        <li><a class="hover:text-terracotta-300" href="/about">About Us</a></li>
      </ul>
    </div>

    <div>
      <p class="font-semibold text-white">Regions in India</p>
      <ul class="mt-3 space-y-2 text-sm text-forest-200">
        {orderedRegions.map((region) => region && (
          <li><a class="hover:text-terracotta-300" href={`/regions/${region.data.slug}/`}>{region.data.name}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="font-semibold text-white">Get in touch</p>
      <ul class="mt-3 space-y-2 text-sm text-forest-200">
        <li><a class="hover:text-terracotta-300" href="mailto:hello@tripcamps.com">hello@tripcamps.com</a></li>
        <li><a class="hover:text-terracotta-300" href="/contact">Contact form</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-forest-800 px-4 py-6 text-center text-xs text-forest-300 sm:px-6">
    &copy; {year} Tripcamps. All rights reserved.
  </div>
</footer>
