---
interface Props {
  difficulty: 'Easy' | 'Moderate' | 'Difficult' | 'Strenuous';
  class?: string;
}
const { difficulty, class: className = '' } = Astro.props;

const styles: Record<string, string> = {
  Easy: 'bg-forest-100 text-forest-800',
  Moderate: 'bg-terracotta-100 text-terracotta-700',
  Difficult: 'bg-terracotta-300/60 text-terracotta-700',
  Strenuous: 'bg-forest-900 text-white',
};
---

<span class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ${styles[difficulty]} ${className}`}>
  {difficulty}
</span>
