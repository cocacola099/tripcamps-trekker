---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/url';
---

<BaseLayout
  title="Page Not Found | Tripcamps"
  description="The page you're looking for doesn't exist."
>
  <section class="mx-auto flex min-h-[70vh] max-w-xl flex-col items-center justify-center px-4 text-center sm:px-6">
    <p class="font-display text-6xl text-terracotta-500">404</p>
    <h1 class="mt-4 font-display text-2xl text-forest-900">This trail doesn't exist</h1>
    <p class="mt-3 text-sand-900/70">The page you're looking for may have moved. Let's get you back on track.</p>
    <a href={withBase('/')} class="mt-8 rounded-full bg-forest-900 px-8 py-3 font-semibold text-white hover:bg-forest-800">
      Back to Home
    </a>
  </section>
</BaseLayout>
