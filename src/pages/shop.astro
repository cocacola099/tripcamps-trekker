---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/url';
---

<BaseLayout
  title="Shop — Coming Soon | Tripcamps"
  description="The Tripcamps shop is coming soon: trekking guidebooks, route notes, and gear picks for India and Nepal's best trails."
>
  <section class="mx-auto flex min-h-[70vh] max-w-3xl flex-col items-center justify-center px-4 text-center sm:px-6">
    <span class="rounded-full bg-terracotta-100 px-4 py-1 text-xs font-semibold uppercase tracking-wide text-terracotta-700">
      Coming Soon
    </span>
    <h1 class="mt-6 font-display text-4xl text-forest-900 sm:text-5xl">The Tripcamps Shop</h1>
    <p class="mt-4 text-lg text-sand-900/70">
      We're putting together a collection of trekking guidebooks and route notes for India and Nepal's best trails. Leave your email and we'll let you know the moment it opens.
    </p>

    <form id="shop-notify-form" class="mt-8 flex w-full max-w-md flex-col gap-3 sm:flex-row">
      <label class="sr-only" for="shop-email">Email address</label>
      <input
        id="shop-email"
        type="email"
        required
        placeholder="you@example.com"
        class="flex-1 rounded-full border border-forest-200 px-5 py-3 text-sm focus:border-forest-500 focus:outline-none"
      />
      <button
        type="submit"
        class="rounded-full bg-forest-900 px-6 py-3 font-semibold text-white transition hover:bg-forest-800"
      >
        Notify Me
      </button>
    </form>
    <p id="shop-notify-status" class="mt-3 text-sm text-forest-700" role="status"></p>

    <a href={withBase('/treks')} class="mt-10 text-sm font-semibold text-forest-700 hover:text-terracotta-600">
      &larr; While you wait, explore trekking destinations
    </a>
  </section>
</BaseLayout>

<script>
  const NOTIFY_EMAIL = 'tripcamps.sales@gmail.com';
  const form = document.getElementById('shop-notify-form') as HTMLFormElement;
  const status = document.getElementById('shop-notify-status');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = (document.getElementById('shop-email') as HTMLInputElement).value;
    const subject = 'Notify me when the shop opens';
    const body = `Please notify me at ${email} when the Tripcamps shop opens.`;
    window.location.href = `mailto:${NOTIFY_EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    if (status) {
      status.textContent = "Opening your email app to send this to us — we'll notify you at that address.";
    }
  });
</script>
