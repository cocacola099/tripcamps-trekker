---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TrekCard from '../../../components/TrekCard.astro';
import CTASection from '../../../components/CTASection.astro';
import PhotoCredit from '../../../components/PhotoCredit.astro';
import { withBase } from '../../../utils/url';

export async function getStaticPaths() {
  const regions = await getCollection('regions');
  return regions.map((region) => ({
    params: { country: region.data.countrySlug, region: region.data.slug },
    props: { region },
  }));
}

const { region } = Astro.props;
const { Content } = await render(region);
const { name, country, tagline, heroImage, seoTitle, seoDescription, slug, countrySlug } = region.data;

const allTreks = await getCollection('treks');
const regionTreks = allTreks
  .filter((t) => t.data.regionSlug === slug && t.data.countrySlug === countrySlug)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://tripcamps.com/' },
    { '@type': 'ListItem', position: 2, name: country, item: `https://tripcamps.com/${countrySlug}/` },
    { '@type': 'ListItem', position: 3, name, item: `https://tripcamps.com/${countrySlug}/regions/${slug}/` },
  ],
};
---

<BaseLayout title={seoTitle} description={seoDescription} image={heroImage.src} jsonLd={jsonLd}>
  <section class="relative flex min-h-[50vh] items-end overflow-hidden">
    <img src={withBase(heroImage.src)} alt={heroImage.alt} class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-forest-950 via-forest-950/50 to-forest-950/10"></div>
    <div class="relative mx-auto w-full max-w-6xl px-4 pb-12 text-white sm:px-6">
      <nav class="mb-4 text-xs text-sand-100/80">
        <a href={withBase('/')} class="hover:underline">Home</a> /
        <a href={withBase(`/${countrySlug}/`)} class="hover:underline">{country}</a> /
        <span>{name}</span>
      </nav>
      <p class="text-sm font-semibold uppercase tracking-wide font-accent text-terracotta-300">{country}</p>
      <h1 class="mt-2 font-display text-4xl sm:text-5xl">{name}</h1>
      <p class="mt-3 max-w-2xl text-sand-100/90">{tagline}</p>
      <PhotoCredit author={heroImage.author} license={heroImage.license} sourceUrl={heroImage.sourceUrl} class="mt-4" />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <article class="prose prose-forest max-w-3xl prose-headings:font-display prose-headings:text-forest-900">
      <Content />
    </article>

    <h2 class="mt-14 font-display text-2xl text-forest-900">Treks in {name}</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {regionTreks.map((trek) => <TrekCard trek={trek} />)}
    </div>
  </section>

  <CTASection />
</BaseLayout>
