---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DifficultyBadge from '../../../components/DifficultyBadge.astro';
import StatBadge from '../../../components/StatBadge.astro';
import ItineraryTimeline from '../../../components/ItineraryTimeline.astro';
import CTASection from '../../../components/CTASection.astro';
import TrekCard from '../../../components/TrekCard.astro';
import PhotoCredit from '../../../components/PhotoCredit.astro';
import ShareButton from '../../../components/ShareButton.astro';
import { withBase } from '../../../utils/url';

export async function getStaticPaths() {
  const treks = await getCollection('treks');
  return treks.map((trek) => ({
    params: { country: trek.data.countrySlug, slug: trek.id },
    props: { trek },
  }));
}

const { trek } = Astro.props;
const { Content } = await render(trek);
const {
  title,
  region,
  regionSlug,
  country,
  countrySlug,
  difficulty,
  durationDays,
  maxAltitudeM,
  distanceKm,
  bestSeason,
  startingPoint,
  endingPoint,
  groupSize,
  shortDescription,
  highlights,
  itinerary,
  howToReach,
  permits,
  heroImage,
  seoTitle,
  seoDescription,
} = trek.data;

const trekUrl = withBase(`/${countrySlug}/treks/${trek.id}/`);

const allTreks = await getCollection('treks');
const relatedTreks = allTreks
  .filter((t) => t.id !== trek.id && t.data.regionSlug === regionSlug && t.data.countrySlug === countrySlug)
  .slice(0, 3);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'TouristTrip',
    name: title,
    description: shortDescription,
    touristType: 'Trekker',
    itinerary: itinerary.map((day) => ({
      '@type': 'TouristAttraction',
      name: `Day ${day.day}: ${day.title}`,
      description: day.description,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://tripcamps.com/' },
      { '@type': 'ListItem', position: 2, name: country, item: `https://tripcamps.com/${countrySlug}/` },
      { '@type': 'ListItem', position: 3, name: region, item: `https://tripcamps.com/${countrySlug}/regions/${regionSlug}/` },
      { '@type': 'ListItem', position: 4, name: title, item: `https://tripcamps.com/${countrySlug}/treks/${trek.id}/` },
    ],
  },
];
---

<BaseLayout title={seoTitle} description={seoDescription} image={heroImage.src} type="article" jsonLd={jsonLd}>
  <section class="relative flex min-h-[60vh] items-end overflow-hidden">
    <img src={withBase(heroImage.src)} alt={heroImage.alt} class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-forest-950 via-forest-950/50 to-forest-950/10"></div>
    <ShareButton url={trekUrl} title={title} text={shortDescription} class="absolute right-4 top-4 sm:right-6 sm:top-6" />
    <div class="relative mx-auto w-full max-w-6xl px-4 pb-12 text-white sm:px-6">
      <nav class="mb-4 text-xs text-sand-100/80">
        <a href={withBase('/')} class="hover:underline">Home</a> /
        <a href={withBase(`/${countrySlug}/`)} class="hover:underline">{country}</a> /
        <a href={withBase(`/${countrySlug}/regions/${regionSlug}/`)} class="hover:underline">{region}</a> /
        <span>{title}</span>
      </nav>
      <DifficultyBadge difficulty={difficulty} class="mb-3" />
      <h1 class="font-display text-4xl sm:text-5xl">{title}</h1>
      <p class="mt-3 max-w-2xl text-sand-100/90">{shortDescription}</p>
      <PhotoCredit author={heroImage.author} license={heroImage.license} sourceUrl={heroImage.sourceUrl} class="mt-4" />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pt-6 sm:px-6">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <StatBadge label="Duration" value={`${durationDays} Days`} />
      <StatBadge label="Max Altitude" value={`${maxAltitudeM.toLocaleString()} m`} />
      <StatBadge label="Distance" value={`${distanceKm} km`} />
      <StatBadge label="Best Season" value={bestSeason.join(', ')} />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <article class="prose prose-forest max-w-none prose-headings:font-display prose-headings:text-forest-900">
          <Content />
        </article>

        <h2 class="mt-12 font-display text-2xl text-forest-900">Highlights</h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {highlights.map((h) => (
            <li class="flex items-start gap-2 rounded-xl bg-forest-50 p-3 text-sm text-forest-900">
              <span class="mt-1 text-terracotta-500">&#9679;</span>
              {h}
            </li>
          ))}
        </ul>

        <h2 class="mt-12 font-display text-2xl text-forest-900">Day-by-Day Itinerary</h2>
        <div class="mt-6">
          <ItineraryTimeline itinerary={itinerary} />
        </div>

        <h2 class="mt-12 font-display text-2xl text-forest-900">How to Reach</h2>
        <p class="mt-3 text-sm leading-relaxed text-sand-900/80">{howToReach}</p>

        <h2 class="mt-8 font-display text-2xl text-forest-900">Permits &amp; Essentials</h2>
        <p class="mt-3 text-sm leading-relaxed text-sand-900/80">{permits}</p>
      </div>

      <aside class="h-fit rounded-2xl border border-forest-100 bg-card p-6 shadow-sm lg:sticky lg:top-24">
        <h3 class="font-display text-xl text-forest-900">Trip Snapshot</h3>
        <dl class="mt-4 space-y-3 text-sm">
          <div class="flex justify-between"><dt class="text-sand-900/60">Country</dt><dd class="font-medium text-forest-900">{country}</dd></div>
          <div class="flex justify-between"><dt class="text-sand-900/60">Region</dt><dd class="font-medium text-forest-900">{region}</dd></div>
          <div class="flex justify-between"><dt class="text-sand-900/60">Starting Point</dt><dd class="font-medium text-forest-900">{startingPoint}</dd></div>
          <div class="flex justify-between"><dt class="text-sand-900/60">Ending Point</dt><dd class="font-medium text-forest-900">{endingPoint}</dd></div>
          {groupSize && <div class="flex justify-between"><dt class="text-sand-900/60">Group Size</dt><dd class="font-medium text-forest-900">{groupSize}</dd></div>}
        </dl>
        <a
          href={`${withBase('/contact')}?trek=${encodeURIComponent(title)}`}
          class="mt-6 block rounded-full bg-terracotta-500 px-6 py-3 text-center font-semibold text-white hover:bg-terracotta-600"
        >
          Organize this Trek?
        </a>
      </aside>
    </div>
  </section>

  {relatedTreks.length > 0 && (
    <section class="bg-forest-50 py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <h2 class="font-display text-2xl text-forest-900">More treks in {region}</h2>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {relatedTreks.map((t) => <TrekCard trek={t} />)}
        </div>
      </div>
    </section>
  )}

  <CTASection
    heading={`Ready to trek ${title}?`}
    body="Share your travel dates and group size — we'll take care of permits, logistics, and local support."
    buttonHref={`/contact?trek=${encodeURIComponent(title)}`}
  />
</BaseLayout>
