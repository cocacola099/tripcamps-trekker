---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RegionCard from '../../components/RegionCard.astro';
import TrekCard from '../../components/TrekCard.astro';
import CTASection from '../../components/CTASection.astro';
import PhotoCredit from '../../components/PhotoCredit.astro';
import { withBase } from '../../utils/url';

export async function getStaticPaths() {
  const countries = await getCollection('countries');
  return countries.map((country) => ({
    params: { country: country.data.slug },
    props: { country },
  }));
}

const { country } = Astro.props;
const { Content } = await render(country);
const { name, slug, heroImage, seoTitle, seoDescription } = country.data;

const allRegions = (await getCollection('regions')).filter((r) => r.data.countrySlug === slug);
const allTreks = (await getCollection('treks')).filter((t) => t.data.countrySlug === slug);
const featuredTreks = allTreks.filter((t) => t.data.featured).slice(0, 6);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://tripcamps.com/' },
    { '@type': 'ListItem', position: 2, name, item: `https://tripcamps.com/${slug}/` },
  ],
};
---

<BaseLayout title={seoTitle} description={seoDescription} image={heroImage.src} jsonLd={jsonLd}>
  <section class="relative flex min-h-[50vh] items-end overflow-hidden">
    <img src={withBase(heroImage.src)} alt={heroImage.alt} class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-forest-950 via-forest-950/50 to-forest-950/10"></div>
    <div class="relative mx-auto w-full max-w-6xl px-4 pb-12 text-white sm:px-6">
      <h1 class="font-display text-4xl sm:text-5xl">{name}</h1>
      <p class="mt-3 text-sm text-sand-100/90">{allRegions.length} regions &middot; {allTreks.length} treks</p>
      <PhotoCredit author={heroImage.author} license={heroImage.license} sourceUrl={heroImage.sourceUrl} class="mt-4" />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <article class="prose prose-forest max-w-3xl prose-headings:font-display prose-headings:text-forest-900">
      <Content />
    </article>

    <h2 class="mt-14 font-display text-2xl text-forest-900">Regions in {name}</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {allRegions.map((region) => (
        <RegionCard region={region} trekCount={allTreks.filter((t) => t.data.regionSlug === region.data.slug).length} />
      ))}
    </div>

    {featuredTreks.length > 0 && (
      <>
        <h2 class="mt-16 font-display text-2xl text-forest-900">Popular treks in {name}</h2>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredTreks.map((trek) => <TrekCard trek={trek} />)}
        </div>
      </>
    )}
  </section>

  <CTASection />
</BaseLayout>
