---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TrekCard from '../components/TrekCard.astro';
import RegionCard from '../components/RegionCard.astro';
import CTASection from '../components/CTASection.astro';
import PhotoCredit from '../components/PhotoCredit.astro';
import attributions from '../data/attributions.json';
import { REGION_ORDER } from '../data/regions';

const allTreks = await getCollection('treks');
const featuredTreks = allTreks.filter((t) => t.data.featured).slice(0, 6);

const allRegions = await getCollection('regions');
const orderedRegions = REGION_ORDER.map((slug) => allRegions.find((r) => r.data.slug === slug)).filter(Boolean);
const trekCountByRegion = Object.fromEntries(
  orderedRegions.map((r) => [r!.data.slug, allTreks.filter((t) => t.data.regionSlug === r!.data.slug).length])
);

const homeHero = attributions['home-hero'];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Tripcamps',
  description: 'Information and support to explore and organise trekking trips across the globe, starting with India.',
  url: 'https://tripcamps.com',
};
---

<BaseLayout
  title="Tripcamps — Explore Treks & Organise Your Next Trekking Trip"
  description="Discover 30+ trekking destinations across India's Himalaya, Ladakh, Kashmir, Sikkim and the Western Ghats. Get detailed itineraries and let Tripcamps organise your trek."
  image={homeHero.src}
  jsonLd={jsonLd}
>
  <section class="relative flex min-h-[80vh] items-center overflow-hidden">
    <img src={homeHero.src} alt={homeHero.alt} class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-forest-950 via-forest-950/60 to-forest-950/20"></div>
    <div class="relative mx-auto max-w-4xl px-4 py-24 text-center text-white sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-terracotta-300">India &middot; Himalaya &amp; Western Ghats</p>
      <h1 class="mt-4 font-display text-4xl leading-tight sm:text-6xl">
        Explore the world's trekking trails. Let us organise the journey.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-sand-100/90">
        Tripcamps helps you discover trekking destinations across the globe with detailed itineraries — and connects you with the support to actually go do them.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="/treks" class="rounded-full bg-terracotta-500 px-8 py-3 font-semibold text-white hover:bg-terracotta-600">
          Explore Treks
        </a>
        <a href="/contact" class="rounded-full border border-white/40 px-8 py-3 font-semibold text-white hover:bg-white/10">
          Plan My Trek
        </a>
      </div>
      <PhotoCredit author={homeHero.author} license={homeHero.license} sourceUrl={homeHero.sourceUrl} class="mt-6" />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-3">
      <div>
        <p class="font-display text-2xl text-forest-900">30+</p>
        <p class="mt-1 text-sm text-sand-900/70">Curated trek itineraries across India, and growing.</p>
      </div>
      <div>
        <p class="font-display text-2xl text-forest-900">7 Regions</p>
        <p class="mt-1 text-sm text-sand-900/70">From the Himalaya to the Western Ghats.</p>
      </div>
      <div>
        <p class="font-display text-2xl text-forest-900">End-to-End</p>
        <p class="mt-1 text-sm text-sand-900/70">Information and support to organise your trip, start to summit.</p>
      </div>
    </div>
  </section>

  <section class="bg-forest-50 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex items-end justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-terracotta-600">Explore by region</p>
          <h2 class="mt-2 font-display text-3xl text-forest-900">Where in India would you like to trek?</h2>
        </div>
        <a href="/regions" class="hidden text-sm font-semibold text-forest-700 hover:text-terracotta-600 sm:block">View all regions &rarr;</a>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {orderedRegions.map((region) => region && (
          <RegionCard region={region} trekCount={trekCountByRegion[region.data.slug]} />
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
    <div class="flex items-end justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-terracotta-600">Popular treks</p>
        <h2 class="mt-2 font-display text-3xl text-forest-900">Trails trekkers love</h2>
      </div>
      <a href="/treks" class="hidden text-sm font-semibold text-forest-700 hover:text-terracotta-600 sm:block">View all treks &rarr;</a>
    </div>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featuredTreks.map((trek) => <TrekCard trek={trek} />)}
    </div>
  </section>

  <section class="bg-forest-50 py-20">
    <div class="mx-auto max-w-5xl px-4 text-center sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-wide text-terracotta-600">How it works</p>
      <h2 class="mt-2 font-display text-3xl text-forest-900">From daydream to trailhead</h2>
      <div class="mt-10 grid gap-8 sm:grid-cols-4">
        {[
          { step: '01', title: 'Browse', body: 'Explore treks by region, difficulty, and season.' },
          { step: '02', title: 'Shortlist', body: 'Read the full itinerary, permits, and best time to go.' },
          { step: '03', title: 'Contact Us', body: 'Tell us your dates and group size — we take it from there.' },
          { step: '04', title: 'Trek', body: 'We organise the logistics; you focus on the summit.' },
        ].map((s) => (
          <div>
            <p class="font-display text-3xl text-terracotta-400">{s.step}</p>
            <p class="mt-2 font-semibold text-forest-900">{s.title}</p>
            <p class="mt-1 text-sm text-sand-900/70">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
