---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const treks = (await getCollection('treks')).sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout
  title="Contact Tripcamps — Plan Your Trek"
  description="Tell Tripcamps where you want to trek and we'll help you plan and organise the trip — permits, logistics, and local support included."
>
  <section class="bg-forest-900 py-16 text-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-wide text-terracotta-300">Get in touch</p>
      <h1 class="mt-2 font-display text-4xl">Let's plan your trek</h1>
      <p class="mt-3 max-w-2xl text-forest-100">
        Whether it's one of our 30+ India itineraries or a trek somewhere else in the world, tell us what you have in mind and we'll help you organise it.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-3">
      <div class="space-y-6 lg:col-span-1">
        <div class="rounded-2xl border border-forest-100 bg-white p-6 shadow-sm">
          <h2 class="font-display text-lg text-forest-900">Email</h2>
          <a href="mailto:hello@tripcamps.com" class="mt-1 block text-sm text-terracotta-600 hover:underline">hello@tripcamps.com</a>
        </div>
        <div class="rounded-2xl border border-forest-100 bg-white p-6 shadow-sm">
          <h2 class="font-display text-lg text-forest-900">WhatsApp</h2>
          <p class="mt-1 text-sm text-sand-900/70">Add your WhatsApp business number here — trekkers often prefer a quick chat over email.</p>
        </div>
        <div class="rounded-2xl border border-forest-100 bg-white p-6 shadow-sm">
          <h2 class="font-display text-lg text-forest-900">Response Time</h2>
          <p class="mt-1 text-sm text-sand-900/70">We typically reply within 24 hours with an itinerary and quote tailored to your dates.</p>
        </div>
      </div>

      <div class="lg:col-span-2">
        <form id="contact-form" class="rounded-2xl border border-forest-100 bg-white p-8 shadow-sm">
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="name" class="text-sm font-medium text-forest-900">Full name</label>
              <input id="name" name="name" type="text" required class="mt-1 w-full rounded-lg border border-forest-200 px-4 py-2.5 text-sm focus:border-forest-500 focus:outline-none" />
            </div>
            <div>
              <label for="email" class="text-sm font-medium text-forest-900">Email</label>
              <input id="email" name="email" type="email" required class="mt-1 w-full rounded-lg border border-forest-200 px-4 py-2.5 text-sm focus:border-forest-500 focus:outline-none" />
            </div>
            <div>
              <label for="phone" class="text-sm font-medium text-forest-900">Phone / WhatsApp</label>
              <input id="phone" name="phone" type="tel" class="mt-1 w-full rounded-lg border border-forest-200 px-4 py-2.5 text-sm focus:border-forest-500 focus:outline-none" />
            </div>
            <div>
              <label for="trek" class="text-sm font-medium text-forest-900">Trek you're interested in</label>
              <select id="trek" name="trek" class="mt-1 w-full rounded-lg border border-forest-200 px-4 py-2.5 text-sm focus:border-forest-500 focus:outline-none">
                <option value="">Not sure yet</option>
                {treks.map((trek) => <option value={trek.data.title}>{trek.data.title}</option>)}
                <option value="other">Somewhere else in the world</option>
              </select>
            </div>
          </div>
          <div class="mt-5">
            <label for="message" class="text-sm font-medium text-forest-900">Tell us about your trip</label>
            <textarea id="message" name="message" rows="5" required placeholder="Dates, group size, experience level..." class="mt-1 w-full rounded-lg border border-forest-200 px-4 py-2.5 text-sm focus:border-forest-500 focus:outline-none"></textarea>
          </div>
          <button type="submit" class="mt-6 rounded-full bg-terracotta-500 px-8 py-3 font-semibold text-white hover:bg-terracotta-600">
            Send Inquiry
          </button>
          <p id="contact-status" class="mt-3 text-sm text-forest-700" role="status"></p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // NOTE: this is not wired to a backend yet. Point the form at a real
  // endpoint (e.g. Web3Forms, Formspree, or your own API route) before launch.
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('contact-status');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (status) {
      status.textContent =
        "Thanks! This form isn't connected to an inbox yet — for now, please email hello@tripcamps.com directly.";
    }
  });
</script>
