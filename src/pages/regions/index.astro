---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RegionCard from '../../components/RegionCard.astro';
import { withBase } from '../../utils/url';

const allRegions = await getCollection('regions');
const allTreks = await getCollection('treks');
const countries = (await getCollection('countries')).sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="All Trekking Regions | Tripcamps"
  description="Browse every trekking region Tripcamps covers, across India, Nepal, and Thailand — from the Garhwal Himalaya to the Khumbu to northern Thailand."
>
  <section class="bg-forest-900 py-16 text-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-wide font-accent text-terracotta-300">Explore</p>
      <h1 class="mt-2 font-display text-4xl">All Trekking Regions</h1>
      <p class="mt-3 max-w-2xl text-forest-100">
        {allRegions.length} regions across {countries.length} countries, from the Garhwal Himalaya to the Khumbu.
      </p>
    </div>
  </section>

  {countries.map((country) => {
    const regionsInCountry = allRegions.filter((r) => r.data.countrySlug === country.data.slug);
    return (
      <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
        <div class="flex items-end justify-between">
          <h2 class="font-display text-2xl text-forest-900">{country.data.name}</h2>
          <a href={withBase(`/${country.data.slug}/`)} class="text-sm font-semibold text-forest-700 hover:text-terracotta-600">
            Explore {country.data.name} &rarr;
          </a>
        </div>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {regionsInCountry.map((region) => (
            <RegionCard region={region} trekCount={allTreks.filter((t) => t.data.regionSlug === region.data.slug && t.data.countrySlug === country.data.slug).length} />
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>
